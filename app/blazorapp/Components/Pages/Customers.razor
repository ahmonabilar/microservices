@page "/customers"
@attribute [StreamRendering]
@using blazorapp.Services
@using microservices.shared.Dtos
@inject ICustomerService CustomerClient

<PageTitle>Customers</PageTitle>

<h1>Customers</h1>

<p>This component displays all customers from the database.</p>

@if (isLoading)
{
    <p><em>Loading customers...</em></p>
}
else if (customers == null || customers.Count == 0)
{
    <p><em>No customers found.</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Company</th>
                <th>Email</th>
                <th>Phone</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in customers)
            {
                <tr>
                    <td>@customer.CustomerId</td>
                    <td>@customer.FirstName</td>
                    <td>@customer.LastName</td>
                    <td>@customer.CompanyName</td>
                    <td>@customer.Email</td>
                    <td>@customer.Phone</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CustomerDto>? customers;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            customers = await CustomerClient.GetAllCustomersAsync();
        }
        finally
        {
            isLoading = false;
        }
    }
}
